{
	"name": "recall",
	"version": "1.0.50",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev": "bun --parallel watch-routes dev:api dev:client",
		"dev:api": "bun --watch app.ts",
		"dev:client": "vite",
		"watch-routes": "tsr watch",
		"build": "tsr generate && vite build",
		"start": "bun run app.ts",
		"generate-routes": "tsr generate",
		"db:seed": "bun run ./src/db/seed.ts",
		"db:migrate": "bun drizzle-kit push",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.5.0-beta.9",
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/eden": "^1.4.8",
		"@elysiajs/openapi": "^1.4.14",
		"@elysiajs/static": "^1.4.7",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.162.1",
		"@tanstack/react-router-devtools": "^1.162.1",
		"better-auth": "^1.4.18",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.2.4",
		"drizzle-orm": "^0.45.1",
		"elysia": "latest",
		"lucide-react": "^0.563.0",
		"pg": "^8.18.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "4",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/router-cli": "^1.162.2",
		"@types/react": "^19.2.13",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"bun-plugin-tailwind": "^0.1.2",
		"bun-types": "latest",
		"drizzle-kit": "^0.31.9",
		"lefthook": "^2.1.1",
		"tsx": "^4.21.0",
		"vite": "^7.3.1"
	},
	"module": "src/index.js"
}
